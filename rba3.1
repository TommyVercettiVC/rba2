-- --------------------------------------------------------------------------
-- Mouse troll: yank cursor to a random screen edge + show message box
-- --------------------------------------------------------------------------
function triggerMouseTroll()
    if not HAS_MOUSEMOVE then
        -- Even without mousemoverel, still show the message
        showLegacyMessageBox("use your keyboard, not mouse thx")
        return
    end

    local cam = getCamera()
    local vs = cam.ViewportSize
    local current = UserInputService:GetMouseLocation()
    -- Pick a random edge: top/bottom/left/right
    local edge = math.random(1, 4)
    local target
    if edge == 1 then      -- top
        target = Vector2.new(math.random(50, vs.X - 50), 20)
    elseif edge == 2 then  -- bottom
        target = Vector2.new(math.random(50, vs.X - 50), vs.Y - 20)
    elseif edge == 3 then  -- left
        target = Vector2.new(20, math.random(50, vs.Y - 50))
    else                   -- right
        target = Vector2.new(vs.X - 20, math.random(50, vs.Y - 50))
    end

    -- Move in one big jump (UNDETEK-style "dragged away")
    local delta = target - Vector2.new(current.X, current.Y)
    -- Clamp to a sane magnitude so we don't break anything
    delta = Vector2.new(
        math.clamp(delta.X, -2000, 2000),
        math.clamp(delta.Y, -2000, 2000)
    )
    mousemoverel(delta.X, delta.Y)

    showLegacyMessageBox("use your keyboard, not mouse thx")
end

-- --------------------------------------------------------------------------
-- Legacy Roblox message box (white box, black border, OK button)
-- --------------------------------------------------------------------------
local activeMessageBox = nil

function showLegacyMessageBox(text)
    -- If one is already up, just update its text and reset timer
    if activeMessageBox and activeMessageBox.Parent then
        activeMessageBox:FindFirstChild("BodyLabel").Text = text
        return
    end

    local parent = getGuiParent()
    local box = Instance.new("ScreenGui")
    box.Name = "RagebotLegacyMessageBox"
    box.ResetOnSpawn = false
    box.Parent = parent
    activeMessageBox = box

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 320, 0, 140)
    frame.Position = UDim2.new(0.5, -160, 0.5, -70)
    frame.BackgroundColor3 = Color3.fromRGB(245, 245, 245)
    frame.BorderSizePixel = 2
