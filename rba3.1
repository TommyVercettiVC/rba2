-- --------------------------------------------------------------------------
-- Target part selection
-- --------------------------------------------------------------------------
local function getTargetPart(character)
    if not character then return nil end
    if Config.TargetPart == "Dynamic" then
        local mousePos = getMouseViewport()
        local closestPart, closestDist = nil, math.huge
        local candidateNames = { "Head", "UpperTorso", "LowerTorso", "HumanoidRootPart", "LeftLeg", "RightLeg" }
        for _, name in ipairs(candidateNames) do
            local part = character:FindFirstChild(name)
            if part and part:IsA("BasePart") then
                local sp, onScreen = getCamera():WorldToViewportPoint(part.Position)
                if onScreen then
                    local d = (Vector2.new(sp.X, sp.Y) - mousePos).Magnitude
                    if d < closestDist then
                        closestDist = d
                        closestPart = part
                    end
                end
            end
        end
        return closestPart or character:FindFirstChild("HumanoidRootPart")
    end
    local part = character:FindFirstChild(Config.TargetPart)
    if part and part:IsA("BasePart") then return part end
    return character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
end

-- --------------------------------------------------------------------------
-- Predicted position
-- --------------------------------------------------------------------------
local function calculatePredictedPosition(targetPart, targetCharacter)
    if not targetPart then return nil end
    if not Config.PredictionEnabled then return targetPart.Position end
    local root = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
    local velocity = getPartVelocity(root) or Vector3.zero
    local cam = getCamera()
    local distance = (targetPart.Position - cam.CFrame.Position).Magnitude
    local timeToTarget = Config.BulletSpeed > 0 and (distance / Config.BulletSpeed) or 0
    return targetPart.Position + (velocity * timeToTarget * Config.PredictionStrength)
end

-- --------------------------------------------------------------------------
-- Target finding
-- --------------------------------------------------------------------------
local function findTarget()
    local bestTarget = nil
    local bestPosition = nil
    local closestDistance = Config.FOV
    local mousePos = getMouseViewport()
    local cam = getCamera()
    local camOrigin = cam.CFrame.Position

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local char = player.Character
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            if humanoid and root and humanoid.Health > 0 then
                if Config.TeamCheck and player.Team and LocalPlayer.Team and player.Team == LocalPlayer.Team then
                    continue
                end
                local targetPart = getTargetPart(char)
                if targetPart then
                    local worldPos = calculatePredictedPosition(targetPart, char) or targetPart.Position
                    local screenPos, onScreen = cam:WorldToViewportPoint(worldPos)
                    if onScreen then
                        if Config.VisibilityCheck then
                            local direction = (worldPos - camOrigin)
                            local rayParams = RaycastParams.new()
                            rayParams.FilterType = Enum.RaycastFilterType.Exclude
                            rayParams.FilterDescendantsInstances = { LocalPlayer.Character, cam }
                            rayParams.IgnoreWater = true
                            local result = Workspace:Raycast(camOrigin, direction, rayParams)
                            if result and not result.Instance:IsDescendantOf(char) then
                                continue
                            end
                        end
                        local screenVec = Vector2.new(screenPos.X, screenPos.Y)
                        local distance = (screenVec - mousePos).Magnitude
                        if distance < closestDistance then
                            closestDistance = distance
                            bestTarget = player
                            bestPosition = worldPos
                            if not TargetHistory[player] then TargetHistory[player] = {} end
                            table.insert(TargetHistory[player], { position = targetPart.Position, time = os.clock() })
                            while #TargetHistory[player] > 5 do
                                table.remove(TargetHistory[player], 1)
                            end
                        end
                    end
                end
            end
        end
    end

    if CurrentTarget and bestTarget and CurrentTarget ~= bestTarget then
        if (os.clock() - lastTargetSwitchAt) < Config.ActivationDelay then
            bestTarget = CurrentTarget
            local part = getTargetPart(bestTarget.Character)
            if part then
                bestPosition = calculatePredictedPosition(part, bestTarget.Character) or part.Position
            end
        else
            lastTargetSwitchAt = os.clock()
        end
    elseif bestTarget and not CurrentTarget then
        lastTargetSwitchAt = os.clock()
    end

    return bestTarget, bestPosition
end

-- --------------------------------------------------------------------------
-- Aim stabilization
-- --------------------------------------------------------------------------
local function stabilizedAim(worldPosition, target)
    if not worldPosition or not target then
        SmoothAimProgress = 0
        LastTargetPlayer = nil
        return
    end
    local cam = getCamera()
    local mousePos = getMouseViewport()
    local screenPos, onScreen = cam:WorldToViewportPoint(worldPosition)
    if not onScreen then return end

    local targetVec = Vector2.new(screenPos.X, screenPos.Y)
    local direction = targetVec - mousePos

    if LastTargetPlayer ~= target then
        SmoothAimProgress = 0
        LastTargetPlayer = target
    end

    if Config.StabilizationEnabled then
        local smoothnessFactor   = Config.Smoothness
        local maxChangeFactor    = Config.MaxAngleChange
        local humanizationFactor = Config.HumanizationFactor

        if Config.AimMethod == "Legit" then
            smoothnessFactor   = math.min(0.8, smoothnessFactor + 0.2)
            maxChangeFactor    = math.min(1.5, maxChangeFactor * 0.7)
            humanizationFactor = math.min(0.5, humanizationFactor + 0.2)
        end

        SmoothAimProgress = math.min(1, SmoothAimProgress + (1 - smoothnessFactor) * 0.1)
        local desired = direction * (1 - SmoothAimProgress)
        local maxChange = maxChangeFactor * (1 - SmoothAimProgress)
        if maxChange > 0 and desired.Magnitude > maxChange then
            desired = (desired.Magnitude > 0 and desired.Unit or desired) * maxChange
        end
        desired = desired * Config.LockStrength
        if humanizationFactor > 0 then
            local imperf = Vector2.new(
                (math.random() * 2 - 1) * humanizationFactor * (1 - SmoothAimProgress),
                (math.random() * 2 - 1) * humanizationFactor * (1 - SmoothAimProgress)
            )
            desired = desired + imperf
        end
        direction = desired
    else
        direction = direction * Config.Smoothness
    end

    if direction.Magnitude < 0.5 then return end

    if Config.AimingMode == "Mouse" then
        if HAS_MOUSEMOVE then
            mousemoverel(direction.X, direction.Y)
        end
    else
        if cam.CameraType ~= Enum.CameraType.Scriptable then
            cam.CameraType = Enum.CameraType.Scriptable
        end
        local yawDelta   = -direction.X / 500
        local pitchDelta = -direction.Y / 500
        local newCFrame = CFrame.Angles(0, yawDelta, 0) * cam.CFrame * CFrame.Angles(pitchDelta, 0, 0)
        cam.CFrame = newCFrame
    end
end

-- --------------------------------------------------------------------------
-- Main aimbot tick
-- --------------------------------------------------------------------------
function rageAimbot()
    if not Config.Enabled then return end
    if not LocalPlayer.Character then return end
    local target, position = findTarget()
    if target then
        CurrentTarget = target
        stabilizedAim(position, target)
        if Config.AutoFire then
            local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if tool then tool:Activate() end
        end
    else
        CurrentTarget = nil
        SmoothAimProgress = 0
        LastTargetPlayer = nil
    end
end

-- --------------------------------------------------------------------------
-- ESP
-- --------------------------------------------------------------------------
local function clearPlayerESP(player)
    local cache = ESPCache[player]
    if not cache then return end
    for _, drawing in ipairs(cache) do
        pcall(function() drawing:Remove() end)
    end
    ESPCache[player] = nil
end

local function clearAllESP()
    for player, _ in pairs(ESPCache) do
        clearPlayerESP(player)
    end
    ESPCache = {}
end

local function getTracerOrigin()
    local cam = getCamera()
    local origin
    if Config.TracerOrigin == "Mouse" then
        origin = getMouseViewport()
    elseif Config.TracerOrigin == "Center" then
        origin = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
    elseif Config.TracerOrigin == "Bottom" then
        origin = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y)
    elseif Config.TracerOrigin == "Top" then
        origin = Vector2.new(cam.ViewportSize.X / 2, 0)
    else
        origin = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
    end
    return origin
end

local function buildPlayerESP(player, character, humanoid, head, rootPart)
    if ESPCache[player] then
        for _, d in ipairs(ESPCache[player]) do pcall(function() d:Remove() end) end
    end
    ESPCache[player] = {}

    local cam = getCamera()
    local headPos, headVisible = cam:WorldToViewportPoint(head.Position)
    local rootPos, rootVisible = cam:WorldToViewportPoint(rootPart.Position)
    if not headVisible and not rootVisible then return end

    local height = math.abs(headPos.Y - rootPos.Y) * 2
    if height < 10 then height = 10 end
    local width = height / 2.5
    local cache = ESPCache[player]

    if Config.ESPBoxes then
        local box = newDrawing("Square")
        if box then
            box.Visible   = true
            box.Color     = Config.ESPColor
            box.Thickness = 2
            box.Size      = Vector2.new(width, height)
            box.Position  = Vector2.new(rootPos.X - width/2, rootPos.Y - height/2)
            box.Filled    = false
            table.insert(cache, box)
        end
    end
    if Config.ESPNames then
        local name = newDrawing("Text")
        if name then
            name.Visible      = true
            name.Color        = Config.ESPColor
            name.Size         = 16
            name.Center       = true
            name.Outline      = true
            name.OutlineColor = Color3.fromRGB(0, 0, 0)
            name.Text         = player.Name
            name.Position     = Vector2.new(rootPos.X, rootPos.Y - height/2 - 20)
            table.insert(cache, name)
        end
    end
    if Config.ESPHealth then
        local hp = newDrawing("Text")
        if hp then
            local pct = humanoid.Health / math.max(1, humanoid.MaxHealth)
            hp.Visible      = true
            hp.Color        = Color3.new(1 - pct, pct, 0)
            hp.Size         = 14
            hp.Center       = true
            hp.Outline      = true
            hp.OutlineColor = Color3.fromRGB(0, 0, 0)
            hp.Text         = math.floor(humanoid.Health) .. "/" .. math.floor(humanoid.MaxHealth)
            hp.Position     = Vector2.new(rootPos.X, rootPos.Y - height/2 - 40)
            table.insert(cache, hp)
        end
    end
    if Config.ESPDistance then
        local localChar = LocalPlayer.Character
        local localRoot = localChar and localChar:FindFirstChild("HumanoidRootPart")
        if localRoot then
            local dist = (rootPart.Position - localRoot.Position).Magnitude
            local dt = newDrawing("Text")
            if dt then
                dt.Visible      = true
                dt.Color        = Config.ESPColor
                dt.Size         = 14
                dt.Center       = true
                dt.Outline      = true
                dt.OutlineColor = Color3.fromRGB(0, 0, 0)
                dt.Text         = math.floor(dist) .. " studs"
                dt.Position     = Vector2.new(rootPos.X, rootPos.Y + height/2 + 10)
                table.insert(cache, dt)
            end
        end
    end
    if Config.ESPTracers then
        local tr = newDrawing("Line")
        if tr then
            tr.Visible   = true
            tr.Color     = Config.ESPColor
            tr.Thickness = 1
            tr.From      = getTracerOrigin()
            tr.To        = Vector2.new(rootPos.X, rootPos.Y)
            table.insert(cache, tr)
        end
    end
end

local lastESPUpdate = 0
function updateESP()
    if not Config.ESPEnabled then
        clearAllESP()
        return
    end
    local now = os.clock()
    if now - lastESPUpdate < Config.ESPRefresh then return end
    lastESPUpdate = now

    local activePlayers = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local char = player.Character
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            local head = char:FindFirstChild("Head")
            local root = char:FindFirstChild("HumanoidRootPart")
            if humanoid and humanoid.Health > 0 and head and root then
                activePlayers[player] = true
                buildPlayerESP(player, char, humanoid, head, root)
            end
        end
    end
    for player, _ in pairs(ESPCache) do
        if not activePlayers[player] then
            clearPlayerESP(player)
        end
    end
end

-- --------------------------------------------------------------------------
-- Safety aim
-- --------------------------------------------------------------------------
function checkSafetyAim()
    if not SafetyWarning then return end
    if not Config.SafetyAimEnabled or not LocalPlayer.Character then
        SafetyWarning.Visible = false
        return
    end
    local localRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not localRoot then return end

    local someoneAiming = false
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local char = player.Character
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            if humanoid and humanoid.Health > 0 and root then
                local direction = (localRoot.Position - root.Position).Unit
                local lookVector = root.CFrame.LookVector
                local dot = lookVector:Dot(direction)
                local angle = math.deg(math.acos(math.clamp(dot, -1, 1)))
                if angle < 30 then
                    someoneAiming = true
                    break
                end
            end
        end
    end

    SafetyWarning.Visible = someoneAiming
    if someoneAiming then
        local pulse = math.sin(os.clock() * 5) * 0.5 + 0.5
        SafetyWarning.Transparency = 1 - pulse
    else
        SafetyWarning.Transparency = 0
    end
end

-- --------------------------------------------------------------------------
-- Auto-adjust
-- --------------------------------------------------------------------------
function autoAdjustSettings()
    if not Config.AutoAdjustEnabled then return end
    local now = os.clock()
    if now - lastAutoAdjustAt < 0.5 then return end
    lastAutoAdjustAt = now

    local enemyCount = 0
    local totalDistance = 0
    local closestDist = math.huge
    local fastestSpeed = 0
    local cam = getCamera()
    local camOrigin = cam.CFrame.Position

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local char = player.Character
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            if humanoid and humanoid.Health > 0 and root then
                if Config.TeamCheck and player.Team and LocalPlayer.Team and player.Team == LocalPlayer.Team then
                    continue
                end
                enemyCount = enemyCount + 1
                local d = (root.Position - camOrigin).Magnitude
                totalDistance = totalDistance + d
                if d < closestDist then closestDist = d end
                local history = TargetHistory[player]
                if history and #history > 1 then
                    local latest = history[#history]
                    local prev = history[1]
                    local dt = latest.time - prev.time
                    if dt > 0 then
                        local moved = (latest.position - prev.position).Magnitude
                        local speed = moved / dt
                        if speed > fastestSpeed then fastestSpeed = speed end
                    end
                end
            end
        end
    end

    if enemyCount > 0 then
        local avgDist = totalDistance / enemyCount
        Config.FOV                = math.clamp(60 + (enemyCount * 15) + (avgDist / 10), 50, 250)
        Config.Smoothness         = math.clamp(0.2 + (avgDist / 100) - (fastestSpeed / 50), 0.1, 0.8)
        Config.PredictionStrength = math.clamp(fastestSpeed / 50, 0.05, 0.3)
        Config.StabilizationEnabled = enemyCount <= 3
        Config.HumanizationFactor = math.clamp(0.1 + (enemyCount / 20), 0.1, 0.4)
        for field, refresh in pairs(SliderRegistry) do
            refresh()
        end
        if FOVCircle then FOVCircle.Radius = Config.FOV end
        -- Refresh visible menu labels too
        for i = 1, #MenuItems do refreshMenuItem(i) end
    end
end

