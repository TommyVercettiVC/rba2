-- Format an item's value for display
local function formatItemValue(item)
    local v = Config[item.field]
    if item.kind == "toggle" then
        return v and "[ON]" or "[OFF]"
    elseif item.kind == "slider" then
        if item.precision == 0 then
            return tostring(math.floor(v))
        else
            return string.format("%." .. item.precision .. "f", v)
        end
    elseif item.kind == "dropdown" then
        return tostring(v)
    end
    return ""
end

-- Refresh a single menu row's label text
function refreshMenuItem(idx)
    local item = MenuItems[idx]
    local label = MenuItemLabels[idx]
    if not item or not label then return end
    label.Text = string.format("%-22s %s", item.label, formatItemValue(item))
end

-- --------------------------------------------------------------------------
-- Menu navigation
-- --------------------------------------------------------------------------
function navigateMenu(direction)
    local n = #MenuItems
    if n == 0 then return end
    SelectedIdx = SelectedIdx + direction
    if SelectedIdx < 1 then SelectedIdx = n end
    if SelectedIdx > n then SelectedIdx = 1 end
    -- Move the highlight frame
    if SelectionHighlight then
        SelectionHighlight.Position = UDim2.new(0, 4, 0, 40 + (SelectedIdx - 1) * 22)
    end
end

-- Change the currently selected item's value (left = -1, right = +1)
function changeSelectedItem(direction)
    local item = MenuItems[SelectedIdx]
    if not item then return end

    if item.kind == "toggle" then
        -- Left = OFF, Right = ON
        Config[item.field] = (direction > 0)
    elseif item.kind == "dropdown" then
        local options = item.options
        local current = Config[item.field]
        local idx = 1
        for i, opt in ipairs(options) do
            if opt == current then idx = i break end
        end
        local nextIdx = idx + direction
        if nextIdx < 1 then nextIdx = #options end
        if nextIdx > #options then nextIdx = 1 end
        Config[item.field] = options[nextIdx]
    elseif item.kind == "slider" then
        local v = Config[item.field] + (direction * item.step)
        v = math.clamp(v, item.min, item.max)
        if item.precision == 0 then
            v = math.floor(v)
        else
            v = math.floor(v * (10 ^ item.precision)) / (10 ^ item.precision)
        end
        Config[item.field] = v
    end

    -- Side effects
    if item.field == "FOV" and FOVCircle then
        FOVCircle.Radius = Config.FOV
    elseif item.field == "CrosshairSize" or item.field == "CrosshairThickness"
        or item.field == "CrosshairType" or item.field == "CrosshairEnabled" then
        createCrosshair()
    elseif item.field == "SafetyAimEnabled" then
        createSafetyWarning()
    elseif item.field == "ESPEnabled" and not Config.ESPEnabled then
        clearAllESP()
    end

    refreshMenuItem(SelectedIdx)
end

-- --------------------------------------------------------------------------
-- Custom drag (only the title bar drags the frame)
-- --------------------------------------------------------------------------
local function makeDraggable(titleBar, frame)
    local dragging, dragStart, startPos
    trackConn(titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
           or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end))
    trackConn(titleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
           or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end))
    trackConn(UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                        or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end))
end

