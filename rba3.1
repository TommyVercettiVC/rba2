-- Executor feature detection
-- --------------------------------------------------------------------------
local HAS_DRAWING   = (typeof(Drawing) == "table" and typeof(Drawing.new) == "function")
local HAS_MOUSEMOVE = type(mousemoverel) == "function"
local HAS_GETHUI    = type(gethui) == "function"
local HAS_GETGENV   = type(getgenv) == "function"

local function getGuiParent()
    if HAS_GETHUI then
        local ok, hui = pcall(gethui)
        if ok and hui then return hui end
    end
    if CoreGui then return CoreGui end
    return LocalPlayer:WaitForChild("PlayerGui")
end

