    FOVCircle.Position = getMouseViewport()
end

-- --------------------------------------------------------------------------
-- Crosshair
-- --------------------------------------------------------------------------
function createCrosshair()
    if Crosshair then
        pcall(function() Crosshair:Remove() end)
        Crosshair = nil
    end
    if not HAS_DRAWING then return end
    Crosshair = newDrawing("Circle")
    if not Crosshair then return end

    if Config.CrosshairType == "Dot" then
        Crosshair.Radius    = 2
        Crosshair.Filled    = true
        Crosshair.Thickness = 1
    elseif Config.CrosshairType == "Octagon" then
        Crosshair.Radius    = Config.CrosshairSize
        Crosshair.Thickness = Config.CrosshairThickness
        Crosshair.NumSides  = 8
        Crosshair.Filled    = false
    else
        Crosshair.Radius    = Config.CrosshairSize
        Crosshair.Thickness = Config.CrosshairThickness
        Crosshair.NumSides  = 32
        Crosshair.Filled    = false
    end

    local cam = getCamera()
    Crosshair.Visible      = Config.CrosshairEnabled
    Crosshair.Color        = Config.CrosshairColor
    Crosshair.Position     = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
    Crosshair.Transparency = 0
end

