-- GUI: dropdown (cycle button)
-- --------------------------------------------------------------------------
local function createDropdown(parent, name, configField, options, yOffset)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 180, 0, 20)
    label.Position = UDim2.new(0, 200, 0, yOffset)
    label.Text = name .. ":"
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = parent

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 180, 0, 30)
    btn.Position = UDim2.new(0, 200, 0, yOffset + 20)
    btn.Text = tostring(Config[configField])
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.BackgroundColor3 = Color3.fromRGB(70, 70, 90)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    btn.Parent = parent
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)

    btn.MouseButton1Click:Connect(function()
        local current = Config[configField]
        local idx = 1
        for i, v in ipairs(options) do
            if v == current then idx = i break end
        end
        -- B76: if current isn't in list, idx stays 1 → cycles to options[2]
        local nextIdx = (idx % #options) + 1
        Config[configField] = options[nextIdx]
        btn.Text = tostring(Config[configField])
        if configField == "CrosshairType" then createCrosshair() end
    end)
    return btn
end

