-- --------------------------------------------------------------------------
-- Helper: robust Drawing creation (fixes B30 — never crashes if Drawing absent)
-- --------------------------------------------------------------------------
local function newDrawing(kind)
    if not HAS_DRAWING then return nil end
    local ok, obj = pcall(Drawing.new, kind)
    if not ok or not obj then return nil end
    return obj
end

-- --------------------------------------------------------------------------
-- Helper: connection tracking (fixes B24 — slider conn leaks)
-- --------------------------------------------------------------------------
local function trackConn(conn)
    if conn then table.insert(Connections, conn) end
    return conn
end

-- --------------------------------------------------------------------------
-- Helper: current camera (fixes B42 — re-fetch if game swaps camera)
-- --------------------------------------------------------------------------
local function getCamera()
    if not Camera or not Camera.Parent then
        Camera = Workspace.CurrentCamera
    end
    return Camera
end

-- --------------------------------------------------------------------------
-- Helper: mouse location in viewport space (fixes B18 — inset mismatch)
-- --------------------------------------------------------------------------
local function getMouseViewport()
    -- UserInputService:GetMouseLocation returns screen space with GUI inset.
    -- Camera:WorldToViewportPoint returns viewport space (no inset).
    -- Convert mouse to viewport space so they're comparable.
    local mouseLoc = UserInputService:GetMouseLocation()
    local cam = getCamera()
    -- ScreenToViewportPoint removes the inset offset.
    local vp, _ = cam:ScreenToViewportPoint(mouseLoc)  -- returns Vector3
    return Vector2.new(vp.X, vp.Y)
end

-- --------------------------------------------------------------------------
-- Helper: get velocity (fixes B13 — Velocity deprecated)
-- --------------------------------------------------------------------------
local function getPartVelocity(part)
    if not part then return Vector3.zero end
    if part.AssemblyLinearVelocity then
        return part.AssemblyLinearVelocity
    elseif part.Velocity then
        return part.Velocity  -- legacy fallback
    end
    return Vector3.zero
end

