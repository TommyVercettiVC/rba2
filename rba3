-- --------------------------------------------------------------------------
-- Connections / main loops
-- --------------------------------------------------------------------------
local function initializeConnections()
    -- Clean any pre-existing connections (idempotent init)
    for _, c in ipairs(Connections) do pcall(function() c:Disconnect() end) end
    Connections = {}

    -- Main loop: aim + FOV + crosshair position + safety + auto-adjust
    -- Use RenderStepped for everything visual (fixes B41)
    trackConn(RunService.RenderStepped:Connect(function()
        updateFOVCircle()
        rageAimbot()
        if Crosshair then
            local cam = getCamera()
            Crosshair.Position = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
        end
        autoAdjustSettings()
    end))

    -- ESP also on RenderStepped ( Drawing objects are screen-space )
    trackConn(RunService.RenderStepped:Connect(function()
        updateESP()
        checkSafetyAim()
    end))

    -- Hotkeys (fixes B49 — ignore while typing)
    trackConn(UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if UserInputService:GetFocusedTextBox() then return end  -- B49 chat guard

        if input.KeyCode == Enum.KeyCode.Insert then
            if GUIInstance then
                GUIInstance.Enabled = not GUIInstance.Enabled
                Config.GUIVisible = GUIInstance.Enabled
            else
                createGUI()
            end
        elseif input.KeyCode == Enum.KeyCode.F then
            Config.Enabled = not Config.Enabled
        elseif input.KeyCode == Enum.KeyCode.R then
            SmoothAimProgress = 0
            LastTargetPlayer = nil
        end
    end))

    -- Player leaving (fixes B40 / B53 — ESP cache cleanup)
    trackConn(Players.PlayerRemoving:Connect(function(player)
        clearPlayerESP(player)
        TargetHistory[player] = nil
    end))

    -- LocalPlayer character death/respawn — clean local references
    trackConn(LocalPlayer.CharacterAdded:Connect(function()
        SmoothAimProgress = 0
        LastTargetPlayer = nil
    end))

    -- Camera swap (fixes B42)
    trackConn(Workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
        Camera = Workspace.CurrentCamera
    end))
end

-- --------------------------------------------------------------------------
-- Cleanup (fixes B9, B29, B43)
-- --------------------------------------------------------------------------
local function cleanup()
    -- Disconnect all tracked connections
    for _, c in ipairs(Connections) do
        pcall(function() c:Disconnect() end)
    end
    Connections = {}  -- B43

    -- Drawing objects
    if FOVCircle then pcall(function() FOVCircle:Remove() end) FOVCircle = nil end
    if Crosshair then pcall(function() Crosshair:Remove() end) Crosshair = nil end
    if SafetyWarning then pcall(function() SafetyWarning:Remove() end) SafetyWarning = nil end

    -- ESP
    clearAllESP()

    -- GUI
    if GUIInstance then
        pcall(function() GUIInstance:Destroy() end)
        GUIInstance = nil
    else
        local existing = getGuiParent():FindFirstChild("RagebotGUI")
        if existing then pcall(function() existing:Destroy() end) end
    end

    -- Restore camera type if we changed it
    if Camera and Camera.CameraType == Enum.CameraType.Scriptable then
        Camera.CameraType = Enum.CameraType.Custom
    end
end

-- --------------------------------------------------------------------------
-- Unload hook (fixes B8 — try multiple executor signals)
-- --------------------------------------------------------------------------
local function hookUnload()
    -- Pattern 1: Synapse X / Krnl / Wave
    if HAS_GETGENV then
        local genv = getgenv()
        if type(genv) == "table" then
            -- Synapse-style: hook the metatable __gc on the script env
            -- Many executors fire a "shutdown" or "unload" signal:
            for _, signalName in ipairs({ "SynapseUnload", "unload", "shutdown", "on_unload" }) do
                local sig = genv[signalName]
                if typeof(sig) == "RBXScriptSignal" then
                    sig:Connect(cleanup)
                    return
                end
            end
        end
    end

    -- Pattern 2: bind to engine signals that fire on shutdown
    pcall(function()
        if game:GetService("ScriptContext") then
            -- Best-effort: cleanup on CoreGui being destroyed
            game.Destroying:Connect(cleanup)
        end
    end)

    -- Pattern 3: expose a global cleanup the user can call manually
    if HAS_GETGENV then
        getgenv().RagebotUnload = cleanup
    end
end

-- --------------------------------------------------------------------------
-- Safe init (fixes B7 — bounded retries; B45 — pcall guard)
-- --------------------------------------------------------------------------
local function safeInitialize()
    local maxRetries = 3
    for attempt = 1, maxRetries do
        local ok, err = pcall(function()
            if HAS_DRAWING then
                FOVCircle = newDrawing("Circle")
            end
            configureFOVCircle()
            createSafetyWarning()
            createCrosshair()
            createGUI()
            initializeConnections()
        end)
        if ok then
            hookUnload()
            return true
        end
        warn(string.format("[Ragebot] Init attempt %d/%d failed: %s", attempt, maxRetries, tostring(err)))
        task.wait(1)
    end
    warn("[Ragebot] Init failed after " .. maxRetries .. " attempts. Aborting.")
    return false
end

-- --------------------------------------------------------------------------
-- Boot
-- --------------------------------------------------------------------------
local ok, err = pcall(safeInitialize)
if not ok then
    warn("[Ragebot] Unrecoverable init error: " .. tostring(err))
    return
end

if HAS_DRAWING and FOVCircle then
    -- Show a brief loaded notification via Drawing.Text instead of a ScreenGui
    task.spawn(function()
        local note = newDrawing("Text")
        if not note then return end
        local cam = getCamera()
        note.Text = "Ragebot v3.0 (Fixed) loaded"
        note.Color = Color3.fromRGB(120, 220, 120)
        note.Size = 18
        note.Center = true
        note.Outline = true
        note.OutlineColor = Color3.fromRGB(0, 0, 0)
        note.Position = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y - 60)
        note.Visible = true
        task.delay(4, function()
            pcall(function() note:Remove() end)
        end)
    end)
end

