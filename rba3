local function createToggleButton(parent, name, configField, yOffset)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(0, 180, 0, 30)
    button.Position = UDim2.new(0, 10, 0, yOffset)
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Font = Enum.Font.Gotham
    button.TextSize = 14
    button.Parent = parent
    Instance.new("UICorner", button).CornerRadius = UDim.new(0, 4)

    local function refresh()
        button.Text = name .. ": " .. (Config[configField] and "ON" or "OFF")
        button.BackgroundColor3 = Config[configField]
            and Color3.fromRGB(50, 150, 50) or Color3.fromRGB(150, 50, 50)
    end
    refresh()

    button.MouseButton1Click:Connect(function()
        Config[configField] = not Config[configField]
        refresh()
        if configField == "FOVCircleVisible" and FOVCircle then
            FOVCircle.Visible = Config.FOVCircleVisible
        elseif configField == "CrosshairEnabled" then
            createCrosshair()
        elseif configField == "SafetyAimEnabled" then
            createSafetyWarning()
        elseif configField == "ESPEnabled" and not Config.ESPEnabled then
            clearAllESP()
        end
    end)
    return button
end

